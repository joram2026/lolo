rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the Admin (love@gmail.com)
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'love@gmail.com';
    }

    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if the document belongs to the logged-in user
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read, list: if isAuth();
      // A user can create their own profile during registration
      allow create: if isAuth() && isOwner(userId);
      // Only owner can update details like password/displayName, but cannot change withdrawal permission or email
      // Admin has complete control over updating anything
      // Non-owner authenticated users can ONLY increment the balance by exactly 0.5, 0.55, 0.6, or 0.7 (referral reward)
      allow update: if isAdmin() || 
                    (isAuth() && isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['withdrawalEnabled', 'email'])) ||
                    (isAuth() && 
                     (request.resource.data.balance == resource.data.balance + 0.5 ||
                      request.resource.data.balance == resource.data.balance + 0.55 ||
                      request.resource.data.balance == resource.data.balance + 0.6 ||
                      request.resource.data.balance == resource.data.balance + 0.7) && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']));
      allow delete: if isAdmin();
    }

    // Transactions Collection rules
    match /transactions/{transactionId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      // Standard users can submit pending transactions (deposits/withdrawals) or approved virtual transactions (trades/swaps/P2P instant release)
      // Also allow creating an approved referral_reward transaction with valid tiered amounts
      allow create: if isAuth() && (
        (request.resource.data.userId == request.auth.uid && 
         (request.resource.data.status == 'PENDING APPROVAL' || 
          (request.resource.data.status == 'APPROVED' && 
           request.resource.data.type in ['buy_crypto', 'sell_crypto', 'swap_crypto', 'withdraw_p2p']))) ||
        (request.resource.data.type == 'referral_reward' && 
         request.resource.data.amount in [0.5, 0.55, 0.6, 0.7] && 
         request.resource.data.status == 'APPROVED')
      );
      // Standard users cannot edit transaction status or detail, only Admin can approve/decline
      // Exception: standard user can complete P2P sell when they click "I HAVE RECEIVED PAYMENT"
      allow update: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid && 
                    resource.data.status == 'PENDING APPROVAL' && 
                    request.resource.data.status == 'PENDING APPROVAL'); // Allowed to edit details but not status
      allow delete: if isAdmin();
    }

    // Referral Codes mapping rules
    match /referralCodes/{code} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Crypto Networks configuration rules
    match /crypto_networks/{networkId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // P2P Merchants configuration rules
    match /p2p_merchants/{merchantId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Crypto Prices configuration rules
    match /crypto_prices/{symbol} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
